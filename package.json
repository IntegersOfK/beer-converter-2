{
  "name": "beer-converter-server",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "description": "Beer Converter backend — SQLite-backed catalogue + admin + shared sessions.",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "test": "node --test tests/*.test.js",
    "lint": "eslint .",
